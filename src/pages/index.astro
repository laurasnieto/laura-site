---
const categories = [
  {
    title: "Diseño Gráfico",
    slug: "diseno",
    items: [
      { title: "Proyecto editorial", summary: "Diseño de publicación para festival de arte contemporáneo.", img: "https://placehold.co/600x400/e8d5c4/5c3d2e?text=Editorial", tags: ["Editorial", "Print"] },
      { title: "Identidad visual", summary: "Sistema de marca para estudio independiente de arquitectura.", img: "https://placehold.co/600x400/d4b8a0/5c3d2e?text=Identidad", tags: ["Branding", "Identidad"] },
      { title: "Cartelería", summary: "Serie de carteles para ciclo de conciertos de música experimental.", img: "https://placehold.co/600x400/c9a882/5c3d2e?text=Cartel", tags: ["Cartel", "Tipografía"] },
    ]
  },
  {
    title: "Música",
    slug: "musica",
    items: [
      { title: "Base #01", summary: "Loop melódico construido sobre síntesis granular y samples analógicos.", img: "https://placehold.co/600x400/e8d5c4/5c3d2e?text=Base+01", tags: ["Electrónica", "Ambient"] },
      { title: "Base #02", summary: "Exploración rítmica en 7/8 con influencias del jazz modal.", img: "https://placehold.co/600x400/d4b8a0/5c3d2e?text=Base+02", tags: ["Jazz", "Experimental"] },
    ]
  },
  {
    title: "Videojuegos",
    slug: "videojuegos",
    items: [
      { title: "Prototipo: Éter", summary: "Juego de exploración atmosférica en entorno 2D generativo.", img: "https://placehold.co/600x400/e8d5c4/5c3d2e?text=Éter", tags: ["2D", "Godot"] },
      { title: "Game jam 2024", summary: "Proyecto de 48h sobre el concepto de memoria y olvido.", img: "https://placehold.co/600x400/d4b8a0/5c3d2e?text=Game+Jam", tags: ["Game Jam", "Narrativa"] },
    ]
  },
]
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>Portfolio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --cream: #f7f2ec;
        --terracota: #b85c38;
        --terracota-light: #e8d5c4;
        --terracota-dark: #5c3d2e;
        --text: #2a1f1a;
        --muted: #8a6f5e;
        --serif: 'Cormorant Garamond', Georgia, serif;
        --sans: 'DM Sans', system-ui, sans-serif;
        --max: 1200px;
      }

      html { scroll-behavior: smooth; }
      body { background: var(--cream); color: var(--text); font-family: var(--sans); font-weight: 300; }

      /* NAV */
      nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem 3rem;
        background: var(--cream);
        border-bottom: 1px solid var(--terracota-light);
      }

      .nav-logo {
        font-family: var(--serif);
        font-size: 1.25rem;
        font-weight: 400;
        color: var(--terracota-dark);
        text-decoration: none;
      }

      .nav-links { display: flex; gap: 2.5rem; list-style: none; }

      .nav-links a {
        font-size: 0.8rem;
        font-weight: 400;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
        text-decoration: none;
        transition: color 0.2s;
      }

      .nav-links a:hover { color: var(--terracota); }

      /* HERO */
      .hero {
        min-height: 100svh;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: 0 3rem 5rem;
        max-width: var(--max);
        margin: 0 auto;
      }

      .hero-label {
        font-size: 0.75rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 1.5rem;
        opacity: 0;
        animation: fadeUp 0.8s ease forwards 0.2s;
      }

      .hero-title {
        font-family: var(--serif);
        font-size: clamp(3.5rem, 9vw, 8.5rem);
        font-weight: 300;
        line-height: 0.97;
        color: var(--terracota-dark);
        margin-bottom: 2.5rem;
        max-width: 14ch;
        opacity: 0;
        animation: fadeUp 0.9s ease forwards 0.35s;
      }

      .hero-title em { font-style: italic; color: var(--terracota); }

      .hero-bottom {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 2rem;
        opacity: 0;
        animation: fadeUp 0.9s ease forwards 0.55s;
      }

      .hero-desc {
        max-width: 38ch;
        font-size: 1rem;
        line-height: 1.75;
        color: var(--muted);
      }

      .hero-cta {
        display: inline-block;
        padding: 0.75rem 2rem;
        border: 1px solid var(--terracota);
        color: var(--terracota);
        font-size: 0.8rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        text-decoration: none;
        white-space: nowrap;
        transition: background 0.2s, color 0.2s;
      }

      .hero-cta:hover { background: var(--terracota); color: var(--cream); }

      /* WORK */
      .work {
        padding: 7rem 3rem;
        max-width: var(--max);
        margin: 0 auto;
      }

      .category { margin-bottom: 7rem; }

      .category-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 2.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--terracota-light);
      }

      .category-title {
        font-family: var(--serif);
        font-size: 2.5rem;
        font-weight: 300;
        color: var(--terracota-dark);
      }

      .category-count {
        font-size: 0.75rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2.5rem;
      }

      .card {
        cursor: pointer;
        opacity: 0;
        transform: translateY(20px);
      }

      .card.visible { animation: fadeUp 0.6s ease forwards; }
      .card:hover .card-img { filter: saturate(1); transform: scale(1.02); }

      .card-img-wrap {
        overflow: hidden;
        aspect-ratio: 3/2;
      }

      .card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        filter: saturate(0.8);
        transition: filter 0.4s, transform 0.4s;
      }

      .card-body { padding: 1rem 0 0; }

      .card-tags {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 0.6rem;
      }

      .tag {
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--terracota);
        background: var(--terracota-light);
        padding: 0.2rem 0.6rem;
        border-radius: 2px;
      }

      .card-title {
        font-family: var(--serif);
        font-size: 1.4rem;
        font-weight: 400;
        color: var(--terracota-dark);
        margin-bottom: 0.4rem;
      }

      .card-summary {
        font-size: 0.85rem;
        line-height: 1.65;
        color: var(--muted);
      }

      /* BIO SECTION */
      .bio-section {
        background: var(--terracota-light);
        padding: 6rem 3rem;
      }

      .bio-inner {
        max-width: var(--max);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1.6fr;
        gap: 5rem;
        align-items: center;
      }

      .bio-photo {
        aspect-ratio: 3/4;
        background: var(--terracota-light);
        border: 1px solid var(--terracota);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: 0.8rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .bio-label {
        font-size: 0.75rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 1rem;
      }

      .bio-title {
        font-family: var(--serif);
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 300;
        line-height: 1.05;
        color: var(--terracota-dark);
        margin-bottom: 1.5rem;
      }

      .bio-title em { font-style: italic; color: var(--terracota); }

      .bio-text {
        font-size: 1rem;
        line-height: 1.8;
        color: var(--text);
        margin-bottom: 2rem;
      }

      .bio-link {
        font-size: 0.8rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--terracota);
        text-decoration: none;
        border-bottom: 1px solid var(--terracota);
        padding-bottom: 2px;
        transition: opacity 0.2s;
      }

      .bio-link:hover { opacity: 0.6; }

      /* CTA FINAL */
      .cta-section {
        background: var(--terracota-dark);
        padding: 7rem 3rem;
        text-align: center;
      }

      .cta-label {
        font-size: 0.75rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--terracota-light);
        margin-bottom: 1.5rem;
        opacity: 0.7;
      }

      .cta-title {
        font-family: var(--serif);
        font-size: clamp(2.5rem, 6vw, 5rem);
        font-weight: 300;
        line-height: 1.05;
        color: var(--cream);
        margin-bottom: 2.5rem;
      }

      .cta-title em { font-style: italic; color: var(--terracota-light); }

      .cta-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
      }

      .btn-primary {
        display: inline-block;
        padding: 0.9rem 2.5rem;
        background: var(--terracota);
        color: var(--cream);
        font-size: 0.8rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        text-decoration: none;
        transition: opacity 0.2s;
      }

      .btn-primary:hover { opacity: 0.85; }

      .btn-secondary {
        display: inline-block;
        padding: 0.9rem 2.5rem;
        border: 1px solid var(--terracota-light);
        color: var(--terracota-light);
        font-size: 0.8rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        text-decoration: none;
        transition: background 0.2s, color 0.2s;
      }

      .btn-secondary:hover { background: var(--terracota-light); color: var(--terracota-dark); }

      /* FOOTER */
      footer {
        padding: 1.5rem 3rem;
        background: var(--terracota-dark);
        border-top: 1px solid rgba(255,255,255,0.1);
        display: flex;
        justify-content: space-between;
        font-size: 0.75rem;
        color: var(--muted);
      }

      /* ANIMATIONS */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      @media (max-width: 768px) {
        nav { padding: 1rem 1.5rem; }
        .hero, .work { padding-left: 1.5rem; padding-right: 1.5rem; }
        .hero-bottom { flex-direction: column; align-items: flex-start; }
        .bio-inner { grid-template-columns: 1fr; gap: 2.5rem; }
        .bio-section { padding: 4rem 1.5rem; }
        .cta-section { padding: 5rem 1.5rem; }
        footer { padding: 1.5rem; }
      }
    </style>
  </head>
  <body>

    <nav>
      <a href="/" class="nav-logo">Nombre Apellido</a>
      <ul class="nav-links">
        <li><a href="#work">Trabajo</a></li>
        <li><a href="/sobre-mi">Sobre mí</a></li>
        <li><a href="/contacto">Contacto</a></li>
      </ul>
    </nav>

    <!-- HERO -->
    <section class="hero">
      <p class="hero-label">Diseño · Música · Videojuegos</p>
      <h1 class="hero-title">
        Trabajo con <em>imagen,</em> sonido e <em>interacción.</em>
      </h1>
      <div class="hero-bottom">
        <p class="hero-desc">
          Placeholder — Descripción breve de quién eres y qué puedes encontrar aquí.
        </p>
        <a href="#work" class="hero-cta">Ver trabajo</a>
      </div>
    </section>

    <!-- WORK -->
    <main class="work" id="work">
      {categories.map((cat) => (
        <section class="category" id={cat.slug}>
          <div class="category-header">
            <h2 class="category-title">{cat.title}</h2>
            <span class="category-count">{cat.items.length} proyectos</span>
          </div>
          <div class="grid">
            {cat.items.map((item) => (
              <article class="card">
                <div class="card-img-wrap">
                  <img src={item.img} alt={item.title} class="card-img" loading="lazy" />
                </div>
                <div class="card-body">
                  <div class="card-tags">
                    {item.tags.map(tag => <span class="tag">{tag}</span>)}
                  </div>
                  <h3 class="card-title">{item.title}</h3>
                  <p class="card-summary">{item.summary}</p>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </main>

    <!-- BIO -->
    <section class="bio-section">
      <div class="bio-inner">
        <div class="bio-photo">Foto</div>
        <div>
          <p class="bio-label">Quién soy</p>
          <h2 class="bio-title">Hola, soy <em>Nombre.</em></h2>
          <p class="bio-text">
            Placeholder — Párrafo breve de presentación. Quién eres, qué te mueve, qué conecta tus disciplinas.
          </p>
          <a href="/sobre-mi" class="bio-link">Saber más →</a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <p class="cta-label">¿Hablamos?</p>
      <h2 class="cta-title">Cuéntame tu <em>proyecto.</em></h2>
      <div class="cta-buttons">
        <a href="/contacto" class="btn-primary">Contactar</a>
        <a href="/sobre-mi" class="btn-secondary">Sobre mí</a>
      </div>
    </section>

    <footer>
      <span>Nombre Apellido</span>
      <span>contacto@email.com</span>
    </footer>

    <script>
      const cards = document.querySelectorAll('.card');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      cards.forEach(card => observer.observe(card));
    </script>

  </body>
</html>
